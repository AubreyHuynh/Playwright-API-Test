# Active environment: dev | sandbox | staging | uat | live
ENV=dev

# REQUIRED on Node.js 22+ — fixes context.conditions SafeSet incompatibility in Playwright 1.61
PLAYWRIGHT_FORCE_ASYNC_LOADER=true

# Base URLs per environment
DEV_BASE_URL=https://reqres.in/api
SANDBOX_BASE_URL=https://reqres.in/api
STAGING_BASE_URL=https://reqres.in/api
UAT_BASE_URL=https://reqres.in/api
LIVE_BASE_URL=https://reqres.in/api

# Credentials per environment
DEV_USERNAME=eve.holt@reqres.in
DEV_PASSWORD=cityslicka
SANDBOX_USERNAME=eve.holt@reqres.in
SANDBOX_PASSWORD=cityslicka
STAGING_USERNAME=
STAGING_PASSWORD=
UAT_USERNAME=
UAT_PASSWORD=
LIVE_USERNAME=
LIVE_PASSWORD=

# Optional API Key (for API Key auth strategy)
API_KEY=

# Framework settings
REQUEST_TIMEOUT_MS=10000
RETRY_COUNT=3
LOG_LEVEL=info
