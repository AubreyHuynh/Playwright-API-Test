# Active environment: dev | sandbox | staging | uat | live
ENV=dev

# REQUIRED on Node.js 22+ — fixes context.conditions SafeSet incompatibility in Playwright 1.61
PLAYWRIGHT_FORCE_ASYNC_LOADER=true

# Base URLs per environment
DEV_BASE_URL=https://fakestoreapi.com
SANDBOX_BASE_URL=https://fakestoreapi.com
STAGING_BASE_URL=https://fakestoreapi.com
UAT_BASE_URL=https://fakestoreapi.com
LIVE_BASE_URL=https://fakestoreapi.com

# Credentials per environment
DEV_USERNAME=johnd
DEV_PASSWORD=m38rmF$
SANDBOX_USERNAME=johnd
SANDBOX_PASSWORD=m38rmF$
STAGING_USERNAME=
STAGING_PASSWORD=
UAT_USERNAME=
UAT_PASSWORD=
LIVE_USERNAME=
LIVE_PASSWORD=

# Optional API Key (for API Key auth strategy)
API_KEY=

# Framework settings
REQUEST_TIMEOUT_MS=10000
RETRY_COUNT=3
LOG_LEVEL=info
AUTH_STATE_PATH=auth-state/token.json
